{
  "name": "clan-salamanca-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite --port 3000",
    "dev:staging": "vite --mode staging",
    "build": "tsc -p tsconfig.json && vite build",
    "build:staging": "tsc -p tsconfig.json && vite build --mode staging",
    "build:production": "tsc -p tsconfig.json && vite build --mode production",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.6.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.1",
    "zod": "^3.24.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.2.6"
  }
}
