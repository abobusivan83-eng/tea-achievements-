# Скопируйте в .env для локальной разработки.
# JWT_SECRET — не короче 16 символов.

APP_ENV=development
# Локальный Postgres:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/clan_salamanca?schema=public"
# Supabase (Render): обе строки обязательны — pooler :6543 для runtime, direct :5432 для prisma db push / migrate.
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/clan_salamanca?schema=public"
JWT_SECRET="change_me_min_16_chars_secret"
PORT=4000

# Публичный URL API (ссылки на /uploads/...). Локально совпадает с API_URL.
API_URL="http://localhost:4000"
PUBLIC_BASE_URL="http://localhost:4000"

# CORS: origin фронта. Несколько доменов через запятую (Vercel prod + preview):
# FRONTEND_ORIGIN="https://app.vercel.app,https://app-git-develop-xxx.vercel.app"
FRONTEND_ORIGIN="http://localhost:3000"

UPLOAD_DIR=uploads
TRUST_PROXY=false

# Почта для кода регистрации (4 цифры).
# Локально (APP_ENV=development) без SMTP_HOST код только в логе сервера.
# На Render (staging/production) без SMTP_HOST регистрация вернёт ошибку — задайте переменные ниже.
#
# Brevo (бывш. Sendinblue): SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587  SMTP_SECURE=false
# Resend: SMTP_HOST=smtp.resend.com  SMTP_PORT=465  SMTP_SECURE=true  SMTP_USER=resend  SMTP_PASS=re_xxxx
# Gmail: приложение-пароль Google, SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_SECURE=true
#
# SMTP_FROM — обязателен для большинства провайдеров (должен совпадать с верифицированным доменом/ящиком).
# SMTP_DEBUG=true — подробный лог SMTP в консоль (только для отладки).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Чайные достижения <noreply@ваш-домен.ru>"
# SMTP_DEBUG=false

# Только для APP_ENV=staging (ЗБТ на Render + Vercel):
# STAGING_ACCESS_TOKEN="минимум_12_символов"
# STAGING_IP_WHITELIST="127.0.0.1"
