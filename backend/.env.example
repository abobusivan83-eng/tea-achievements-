# Скопируйте в .env для локальной разработки.
# JWT_SECRET — не короче 16 символов.

APP_ENV=development
# Локальный Postgres:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/clan_salamanca?schema=public"
# Supabase (Render): обе строки обязательны — pooler :6543 для runtime, direct :5432 для prisma db push / migrate.
# Чтобы не исчерпать лимит соединений Supabase, в конец query DATABASE_URL добавь (через &):
#   connection_limit=5&pool_timeout=20
# Пример: ...?pgbouncer=true&sslmode=require&connection_limit=5&pool_timeout=20
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&connection_limit=5&pool_timeout=20"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/clan_salamanca?schema=public"
JWT_SECRET="change_me_min_16_chars_secret"
PORT=4000

# Публичный URL API (ссылки на /uploads/...). Локально совпадает с API_URL.
API_URL="http://localhost:4000"
PUBLIC_BASE_URL="http://localhost:4000"

# CORS: если указать CORS_ORIGINS, он имеет приоритет над FRONTEND_ORIGIN.
# Несколько доменов через запятую.
# CORS_ORIGINS="https://app.vercel.app,https://app-git-develop-xxx.vercel.app"
# FRONTEND_ORIGIN оставлен для обратной совместимости.
FRONTEND_ORIGIN="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

UPLOAD_DIR=uploads
# Физическое хранилище файлов. Можно вынести на уровень выше backend (например ../uploads).
# В production укажите путь на постоянном диске / volume.
UPLOAD_ROOT_DIR=../uploads
TRUST_PROXY=false
REQUEST_TIMEOUT_MS=20000
SLOW_REQUEST_MS=800
PRISMA_SLOW_QUERY_MS=300

# Cloudinary (медиа для отправки заданий: фото/видео до 100 МБ)
# Вариант 1 (предпочтительно): единая строка подключения.
# CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"
#
# Вариант 2: три поля отдельно (если не используете CLOUDINARY_URL).
# CLOUDINARY_CLOUD_NAME="<cloud_name>"
# CLOUDINARY_API_KEY="<api_key>"
# CLOUDINARY_API_SECRET="<api_secret>"

# --- Telegram (обязательно для регистрации по коду в личке бота) ---
# Без обоих полей API вернёт 503 «Telegram не настроен».
#
# 1) В Telegram открой @BotFather → /newbot (или выбери существующего) → скопируй HTTP API token.
# 2) TELEGRAM_BOT_TOKEN — весь токен вида 123456789:AAH... (без кавычек и пробелов).
# 3) TELEGRAM_BOT_USERNAME — ник бота как в t.me/ИМЯ, БЕЗ символа @ (например TeaCabinetBot).
#
# Render: Dashboard → твой Web Service → Environment → Add Environment Variable (для каждой строки).
# После сохранения сделай Manual Deploy, чтобы подтянулись новые переменные.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=TeaCabinetBot

# Только для APP_ENV=staging (ЗБТ на Render + Vercel):
# STAGING_ACCESS_TOKEN="минимум_12_символов"
# STAGING_IP_WHITELIST="127.0.0.1"
