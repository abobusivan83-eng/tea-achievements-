{
  "name": "clan-salamanca-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "npx prisma generate && tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "db:push": "npx prisma db push",
    "start:staging": "node --env-file=.env.staging dist/src/server.js",
    "start:production": "node --env-file=.env.production dist/src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "media:normalize": "tsx scripts/normalize-media-urls.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cache": "^5.1.2",
    "prisma": "^6.6.0",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "zod": "^3.24.3"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.19.17",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  }
}
